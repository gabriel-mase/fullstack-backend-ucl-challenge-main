{
  "name": "champions-league-draw-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node dist/bin/www.js",
    "build": "prisma generate && tsc",
    "dev": "tsx watch bin/www.ts",
    "dev:all": "concurrently -n backend,frontend -c blue,green \"npm run dev\" \"npm --prefix frontend run dev -- -p 3001\"",
    "prestart": "npm install && npm run build",
    "pretest": "npm install && prisma generate && npm run build",
    "test": "cross-env PORT=8001 NODE_OPTIONS='--import tsx' mocha --reporter mocha-multi-reporters --reporter-options configFile=config.json",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:unit:ui": "vitest --ui",
    "test:unit:coverage": "vitest run --coverage",
    "seed": "tsx src/contexts/teams/infrastructure/seed.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:reset": "rm -f dev.db && npm run prisma:migrate && npm run seed",
    "db:seed": "npm run seed",
    "db:clean": "rm -f dev.db"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.2.0",
    "@prisma/adapter-pg": "^7.1.0",
    "@prisma/client": "^7.2.0",
    "better-sqlite3": "^11.7.0",
    "cookie-parser": "~1.4.7",
    "cors": "^2.8.6",
    "debug": "~4.4.0",
    "dotenv": "^17.2.3",
    "express": "~4.21.2",
    "inversify": "^7.11.0",
    "jade": "^0.29.0",
    "morgan": "~1.10.0",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bluebird": "^3.5.42",
    "@types/chai": "^4.3.11",
    "@types/chai-http": "^4.2.0",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.19",
    "@types/debug": "^4.1.12",
    "@types/express": "^4.17.21",
    "@types/mocha": "^10.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.19.3",
    "@vitest/ui": "^4.0.16",
    "bluebird": "^3.7.2",
    "chai": "^4.5.0",
    "chai-http": "^4.3.0",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "mocha": "^10.8.2",
    "mocha-junit-reporter": "^2.2.1",
    "mocha-multi-reporters": "^1.5.1",
    "prisma": "^7.2.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
